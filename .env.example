# Configuración del Servidor de Base de Datos

# Contraseña del usuario root de MySQL
MYSQL_ROOT_PASSWORD=rootpassword123

# Usuario de solo lectura para los alumnos
# Este usuario tendrá acceso SELECT a TODOS los schemas/databases creados
DB_USER=dam
DB_PASSWORD=dam123

# Puerto expuesto (por defecto 3306)
MYSQL_PORT=3306

# NOTA: No necesitas especificar DB_NAME porque se crearán automáticamente
# todos los schemas que estén en los archivos SQL de la carpeta Creaciones/
