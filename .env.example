# Configuración del Servidor de Base de Datos

# Nombre de la base de datos principal a crear
# Este debe coincidir con el nombre usado en los archivos SQL de la carpeta Creaciones
DB_NAME=tienda_calzado

# Contraseña del usuario root de MySQL
MYSQL_ROOT_PASSWORD=rootpassword123

# Usuario de solo lectura para los alumnos
DB_USER=dam
DB_PASSWORD=dam123

# Puerto expuesto (por defecto 3306)
MYSQL_PORT=3306
